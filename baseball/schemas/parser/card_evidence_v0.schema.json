{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BIE Parsed Card Evidence v0",
  "type": "object",
  "required": [
    "schemaVersion",
    "parserVersion",
    "parsedAt",
    "source",
    "player",
    "role",
    "card",
    "resultEvidence"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "bie.parsed-card-evidence.v0"
    },
    "parserVersion": {
      "type": "string"
    },
    "parsedAt": {
      "type": "string"
    },
    "source": {
      "type": "object",
      "required": [
        "provider",
        "season",
        "htmlPath",
        "metadataPath",
        "sha256",
        "captureStatus"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "const": "strat365"
        },
        "season": {
          "type": "integer"
        },
        "htmlPath": {
          "type": "string"
        },
        "metadataPath": {
          "type": "string"
        },
        "sha256": {
          "type": "string"
        },
        "capturedAt": {
          "type": ["string", "null"]
        },
        "captureStatus": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "player": {
      "type": "object",
      "required": [
        "playerId",
        "playerName"
      ],
      "properties": {
        "playerId": {
          "type": "integer"
        },
        "playerName": {
          "type": "string"
        },
        "team": {
          "type": ["string", "null"]
        },
        "bats": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": true
    },
    "role": {
      "type": "string",
      "enum": ["hitter", "pitcher"]
    },
    "card": {
      "type": "object",
      "required": [
        "balance",
        "rawText"
      ],
      "properties": {
        "balance": {
          "type": ["string", "null"]
        },
        "rawText": {
          "type": "string"
        },
        "rawTables": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "hitterTraits": {
      "type": ["object", "null"],
      "properties": {
        "defenseText": {
          "type": ["string", "null"]
        },
        "runningText": {
          "type": ["string", "null"]
        },
        "stealingText": {
          "type": ["string", "null"]
        },
        "buntingText": {
          "type": ["string", "null"]
        },
        "hitAndRunText": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": true
    },
    "pitcherTraits": {
      "type": ["object", "null"],
      "properties": {
        "throws": {
          "type": ["string", "null"]
        },
        "hold": {
          "type": ["string", "null"]
        },
        "starterText": {
          "type": ["string", "null"]
        },
        "reliefText": {
          "type": ["string", "null"]
        },
        "pitcherText": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": true
    },
    "resultEvidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "section",
          "rawResultText",
          "source"
        ],
        "properties": {
          "section": {
            "type": "string"
          },
          "column": {
            "type": ["string", "null"]
          },
          "row": {
            "type": ["string", "null"]
          },
          "diceRange": {
            "type": ["string", "null"]
          },
          "rawResultText": {
            "type": "string"
          },
          "normalizedLabel": {
            "type": ["string", "null"]
          },
          "source": {
            "type": "object",
            "required": [
              "kind",
              "pointer"
            ],
            "properties": {
              "kind": {
                "type": "string"
              },
              "pointer": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
